PORT=8001

# 默认 false，使用本地规则模式 + MCP 工具，开箱即跑
ENABLE_OPENAI=true

# 若要切换成真实模型推理，将 ENABLE_OPENAI 改成 true 并填写以下参数
LLM_API_KEY=sk-42a9b54b899044c8a85bf6f044dd225e
LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
LLM_MODEL=qwen3.5-plus

# MCP 连接方式: stdio | streamable_http | sse
MCP_TRANSPORT=stdio
# 远程托管 MCP 服务地址，使用 streamable_http / sse 时必填
# MCP_SERVER_URL=https://your-mcp-host.example.com/mcp
# 远程 MCP Bearer Token，可选
# MCP_AUTH_TOKEN=
# 远程 MCP 自定义请求头(JSON)，可选
# MCP_HEADERS={"x-api-key":"your-key"}
